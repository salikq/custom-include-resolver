{
  "name": "custom-include-resolver",
  "displayName": "custom-include-resolver",
  "description": "Resolve custom include paths",
  "repository": "https://github.com/salikq/custom-include-resolver",
  "version": "0.0.1",
  "publisher": "",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.custom-include-workspace.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "customIncludeResolver.reloadWorkspaceConfigs",
        "title": "Custom Include Resolver: Reload Workspace Configs"
      },
      {
        "command": "customIncludeResolver.rebuildFileIndex",
        "title": "Custom Include Resolver: Rebuild File Index"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.5.4"
  }
}
